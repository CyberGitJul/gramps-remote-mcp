GRAMPS_BASE_URL=https://gramps.example.com
GRAMPS_USERNAME=mcp-automation
GRAMPS_PASSWORD=changeme

# Destructive tools (gramps_delete_person, gramps_delete_family,
# gramps_delete_blog_post) are OFF by default and are not even registered. Set to
# 1 to opt in; the account then also needs delete rights on the tree. Leave unset
# for a read/edit-only deployment.
# GRAMPS_ENABLE_DESTRUCTIVE=1

# Blog post body format: "html" stores post bodies as HTML (rendered + sanitized
# by the server); anything else (default) stores plain text. Only the exact
# value "html" enables HTML.
GRAMPS_BLOG_BODY_FORMAT=text
